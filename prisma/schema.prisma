generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Interpreter {
  id                 Int      @id @default(autoincrement())
  externalId         String   @unique
  name               String
  status             String   @default("Activo") // Activo, Training, Inactivo, Probation
  realtimeStatus     String   @default("Offline") @map("realtime_status") // Online, Offline, Busy
  campaign           String?
  languageA          String   @default("Español")
  languageB          String   @default("Inglés")
  emailCorporativo   String?  @unique
  telefono           String?
  pais               String?
  metodoPago         String? // PayPal, Bank Transfer, Payoneer, USDT
  cuentaPago         String?
  documentosCompleto Boolean  @default(false)
  notas              String?
  tariffPerMinute    Decimal  @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  productionLogs ProductionLog[]
  qaScores       QAScore[]
  payrollRecords PayrollRecord[]
  accountRates   InterpreterAccountRate[]
  auditLogs      PayrateAuditLog[]
  callSessions   CallSession[]
  userProfile    UserProfile?

  @@index([status])
  @@index([pais])
  @@index([createdAt])
  @@map("interpreters")
}

model Account {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productionLogs   ProductionLog[]
  interpreterRates InterpreterAccountRate[]

  @@map("accounts")
}

model InterpreterAccountRate {
  id            Int      @id @default(autoincrement())
  interpreterId Int
  accountId     Int
  tariffPerHour Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([interpreterId, accountId])
  @@map("interpreter_account_rates")
}

model ProductionLog {
  id                 Int       @id @default(autoincrement())
  interpreterId      Int
  date               DateTime  @db.Date
  campaign           String?
  scheduledHours     String?
  loginTime          DateTime?
  logoutTime         DateTime?
  connectedHours     Decimal?  @db.Decimal(10, 2)
  interpretedMinutes Int       @default(0)
  callsAttended      Int       @default(0)
  adherence          Decimal?  @db.Decimal(5, 2)
  status             String
  observaciones      String?
  createdAt          DateTime  @default(now())

  interpreter   Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)
  qaScore       QAScore?
  accountId     Int?
  account       Account?    @relation(fields: [accountId], references: [id])

  @@index([date])
  @@index([interpreterId, date])
  @@index([status])
  @@map("production_logs")
}

model QAScore {
  id                  Int      @id @default(autoincrement())
  productionLogId     Int      @unique
  interpreterId       Int
  auditDate           DateTime
  auditor             String?
  callDuration        Int? // minutos
  callType            String? // Médica, Legal, etc
  protocolScore       Decimal? @db.Decimal(5, 2) // 20%
  interpretationScore Decimal? @db.Decimal(5, 2) // 40%
  languageScore       Decimal? @db.Decimal(5, 2) // 20%
  serviceScore        Decimal? @db.Decimal(5, 2) // 10%
  technicalScore      Decimal? @db.Decimal(5, 2) // 10%
  totalScore          Decimal? @db.Decimal(5, 2)
  criticalError       Boolean  @default(false)
  comentarios         String?
  accionRequerida     String? // Ninguna, Coaching, Advertencia
  createdAt           DateTime @default(now())

  productionLog ProductionLog @relation(fields: [productionLogId], references: [id], onDelete: Cascade)
  interpreter   Interpreter   @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([auditDate])
  @@index([interpreterId])
  @@map("qa_scores")
}

model PayrollRecord {
  id                String    @id @default(cuid())
  periodStart       DateTime  @db.Date
  periodEnd         DateTime  @db.Date
  interpreterId     Int
  totalMinutes      Int
  grossTotal        Decimal   @db.Decimal(10, 2)
  qualityBonus      Decimal   @default(0) @db.Decimal(10, 2)
  penalidades       Decimal   @default(0) @db.Decimal(10, 2)
  transferDeduction Decimal   @default(0) @db.Decimal(10, 2)
  netTotal          Decimal   @db.Decimal(10, 2)
  status            String    @default("Pendiente") // Pendiente, Procesando, Pagado
  paymentDate       DateTime?
  createdAt         DateTime  @default(now())

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([periodStart, periodEnd])
  @@index([interpreterId])
  @@index([status])
  @@map("payroll_records")
}

model RecruitmentCandidate {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  telefono         String?
  pais             String?
  fuente           String? // LinkedIn, Facebook, Referido
  englishLevel     String? // C1, C2, B2, etc
  speedtestMbps    Int?
  status           String    @default("Aplicante") // Aplicante, Entrevista Agendada, Rechazado, Contratado
  fechaPostulacion DateTime
  fechaEntrevista  DateTime?
  resultRoleplay   Int? // 0-100
  fechaOferta      DateTime?
  fechaInicio      DateTime?
  responsable      String?
  notas            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([fechaPostulacion])
  @@map("recruitment_candidates")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("system_configs")
}

model PayrateAuditLog {
  id            Int      @id @default(autoincrement())
  interpreterId Int
  oldRate       Decimal  @db.Decimal(10, 2)
  newRate       Decimal  @db.Decimal(10, 2)
  changedBy     String
  changedAt     DateTime @default(now())

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@map("payrate_audit_log")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   // Linked to auth.users ID
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?  // Optional link to action
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model UserProfile {
  id            String   @id @default(uuid())
  email         String   @unique
  displayName   String?  @map("display_name")
  role          String   @default("interpreter")
  interpreterId Int?     @map("interpreter_id") @unique
  createdAt     DateTime @default(now()) @map("created_at")

  interpreter   Interpreter? @relation(fields: [interpreterId], references: [id])

  @@map("user_profiles")
}

model CallSession {
  id              Int       @id @default(autoincrement())
  interpreterId   Int       @map("interpreter_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  tariffSnapshot  Decimal   @db.Decimal(10, 2) @map("tariff_snapshot")
  callCost        Decimal?  @db.Decimal(10, 2) @map("call_cost")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([interpreterId])
  @@index([startedAt])
  @@map("call_sessions")
}


