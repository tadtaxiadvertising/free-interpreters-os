generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Interpreter {
  id                 Int      @id @default(autoincrement())
  externalId         String   @unique @map("external_id")
  name               String
  status             String   @default("Activo")
  realtimeStatus     String   @default("Offline") @map("realtime_status")
  campaign           String?
  languageA          String   @default("Español") @map("language_a")
  languageB          String   @default("Inglés") @map("language_b")
  emailCorporativo   String?  @unique @map("email_corporativo")
  telefono           String?
  pais               String?
  metodoPago         String?  @default("Transferencia Bancaria") @map("metodo_pago")
  cuentaPago         String?  @map("cuenta_pago")
  banco              String?
  tipoCuenta         String?  @map("tipo_cuenta")
  cedulaRnc          String?  @map("cedula_rnc")
  documentosCompleto Boolean  @default(false) @map("documentos_completo")
  notas              String?  @db.Text
  tariffPerMinute    Decimal  @db.Decimal(10, 2) @map("tariff_per_minute")
  monthlyGoal        Int      @default(2000) @map("monthly_goal")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  productionLogs ProductionLog[]
  qaScores       QAScore[]
  payrollRecords PayrollRecord[]
  accountRates   InterpreterAccountRate[]
  auditLogs      PayrateAuditLog[]
  callSessions   CallSession[]
  userProfile    UserProfile?

  @@index([status])
  @@index([pais])
  @@index([createdAt])
  @@map("interpreters")
}

model Account {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productionLogs   ProductionLog[]
  interpreterRates InterpreterAccountRate[]

  @@map("accounts")
}

model InterpreterAccountRate {
  id            Int      @id @default(autoincrement())
  interpreterId Int      @map("interpreter_id")
  accountId     Int      @map("account_id")
  tariffPerHour Decimal  @db.Decimal(10, 2) @map("tariff_per_hour")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([interpreterId, accountId])
  @@map("interpreter_account_rates")
}

model ProductionLog {
  id                 Int       @id @default(autoincrement())
  interpreterId      Int       @map("interpreter_id")
  date               DateTime  @db.Date
  campaign           String?
  scheduledHours     String?   @map("scheduled_hours")
  loginTime          DateTime? @map("login_time")
  logoutTime         DateTime? @map("logout_time")
  connectedHours     Decimal?  @db.Decimal(10, 2) @map("connected_hours")
  interpretedMinutes Int       @default(0) @map("interpreted_minutes")
  callsAttended      Int       @default(0) @map("calls_attended")
  adherence          Decimal?  @db.Decimal(5, 2)
  status             String
  observaciones      String?
  createdAt          DateTime  @default(now()) @map("created_at")

  interpreter   Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)
  qaScore       QAScore?
  accountId     Int?        @map("account_id")
  account       Account?    @relation(fields: [accountId], references: [id])

  @@index([date])
  @@index([interpreterId, date])
  @@index([status])
  @@map("production_logs")
}

model QAScore {
  id                  Int      @id @default(autoincrement())
  productionLogId     Int      @unique @map("production_log_id")
  interpreterId       Int      @map("interpreter_id")
  auditDate           DateTime @map("audit_date")
  auditor             String?
  callDuration        Int?     @map("call_duration")
  callType            String?  @map("call_type")
  protocolScore       Decimal? @db.Decimal(5, 2) @map("protocol_score")
  interpretationScore Decimal? @db.Decimal(5, 2) @map("interpretation_score")
  languageScore       Decimal? @db.Decimal(5, 2) @map("language_score")
  serviceScore        Decimal? @db.Decimal(5, 2) @map("service_score")
  technicalScore      Decimal? @db.Decimal(5, 2) @map("technical_score")
  totalScore          Decimal? @db.Decimal(5, 2) @map("total_score")
  criticalError       Boolean  @default(false) @map("critical_error")
  comentarios         String?
  accionRequerida     String?  @map("accion_requerida")
  createdAt           DateTime @default(now()) @map("created_at")

  productionLog ProductionLog @relation(fields: [productionLogId], references: [id], onDelete: Cascade)
  interpreter   Interpreter   @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([auditDate])
  @@index([interpreterId])
  @@map("qa_scores")
}

model PayrollRecord {
  id                String    @id @default(cuid())
  periodStart       DateTime  @db.Date @map("period_start")
  periodEnd         DateTime  @db.Date @map("period_end")
  interpreterId     Int       @map("interpreter_id")
  totalMinutes      Int       @map("total_minutes")
  grossTotal        Decimal   @db.Decimal(10, 2) @map("gross_total")
  qualityBonus      Decimal   @default(0) @db.Decimal(10, 2) @map("quality_bonus")
  penalidades       Decimal   @default(0) @db.Decimal(10, 2)
  transferDeduction Decimal   @default(0) @db.Decimal(10, 2) @map("transfer_deduction")
  netTotal          Decimal   @db.Decimal(10, 2) @map("net_total")
  status            String    @default("Pendiente")
  paymentDate       DateTime? @map("payment_date")
  createdAt         DateTime  @default(now()) @map("created_at")

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([periodStart, periodEnd])
  @@index([interpreterId])
  @@index([status])
  @@map("payroll_records")
}

model RecruitmentCandidate {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  telefono         String?
  pais             String?
  fuente           String?
  englishLevel     String?   @map("english_level")
  speedtestMbps    Int?      @map("speedtest_mbps")
  status           String    @default("Aplicante")
  fechaPostulacion DateTime  @map("fecha_postulacion")
  fechaEntrevista  DateTime? @map("fecha_entrevista")
  resultRoleplay   Int?      @map("result_roleplay")
  fechaOferta      DateTime? @map("fecha_oferta")
  fechaInicio      DateTime? @map("fecha_inicio")
  responsable      String?
  notas            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([fechaPostulacion])
  @@map("recruitment_candidates")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("system_configs")
}

model PayrateAuditLog {
  id            Int      @id @default(autoincrement())
  interpreterId Int      @map("interpreter_id")
  oldRate       Decimal  @db.Decimal(10, 2) @map("old_rate")
  newRate       Decimal  @db.Decimal(10, 2) @map("new_rate")
  changedBy     String   @map("changed_by")
  changedAt     DateTime @default(now()) @map("changed_at")
  details       String?  @db.Text

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@map("payrate_audit_log")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model UserProfile {
  id                 String    @id @default(uuid())
  email              String    @unique
  displayName        String?   @map("display_name")
  role               String    @default("interpreter")
  interpreterId      Int?      @map("interpreter_id") @unique
  termsAcceptedAt    DateTime? @map("terms_accepted_at")
  signatureDate      DateTime? @map("signature_date")
  bankName           String?   @map("bank_name")
  bankAccount        String?   @map("bank_account")
  bankAccountType    String?   @map("bank_account_type")
  bankCedula         String?   @map("bank_cedula")
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  createdAt          DateTime  @default(now()) @map("created_at")

  interpreter   Interpreter? @relation(fields: [interpreterId], references: [id])

  @@map("user_profiles")
}

model CallSession {
  id              Int       @id @default(autoincrement())
  interpreterId   Int       @map("interpreter_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  tariffSnapshot  Decimal   @db.Decimal(10, 2) @map("tariff_snapshot")
  callCost        Decimal?  @db.Decimal(10, 2) @map("call_cost")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  interpreter Interpreter @relation(fields: [interpreterId], references: [id], onDelete: Cascade)

  @@index([interpreterId])
  @@index([startedAt])
  @@map("call_sessions")
}
