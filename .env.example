# ─────────────────────────────────────────────────────────────────────────────
# FREE INTERPRETERS OS — ENVIRONMENT CONFIGURATION
# Target: Easypanel (Docker/VPS) + Supabase
# ─────────────────────────────────────────────────────────────────────────────
# ⚠ IMPORTANT: Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# --- FRONTEND (interpreters) ---
# Required for client-side Supabase and API communication
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
NEXT_PUBLIC_API_URL="https://api.freeinterpreters.com"

# --- BACKEND (interpreters-api) ---
# Required for Prisma and CORS security
DATABASE_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:5432/postgres"

# CORS: Dominio exacto del Frontend (sin trailing slash)
# Usado por next.config.ts y middleware.ts para restringir acceso cross-origin
FRONTEND_ORIGIN="https://app.freeinterpreters.com"

# --- AUTH & SECURITY ---
AUTH_SECRET="generate-a-random-32-char-string"
ENCRYPTION_KEY="generate-a-random-64-hex-string"

# ⚠️ RUNTIME-ONLY — Supabase Admin (service_role) key.
# Required for admin operations: user creation, email confirmation, password
# reset, user deletion. Set this in your Easypanel / VPS runtime environment.
#
# DO NOT pass this as a Docker build arg or bake it into the image.
# The application degrades gracefully without it: admin-only operations
# return a safe error response, but the server stays healthy.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- SHARED ---
NODE_ENV="production"

