# ─────────────────────────────────────────────────────────────────────────────
# FREE INTERPRETERS OS — ENVIRONMENT CONFIGURATION (v4.0.0)
# Target: Easypanel (Docker/VPS) + Supabase
# ─────────────────────────────────────────────────────────────────────────────
# ⚠ IMPORTANT: Copy this file to .env and fill in your real values.
#   - Variables prefixed with NEXT_PUBLIC_* are inlined at build time.
#   - All other variables are runtime-only (injected into the container).
# ─────────────────────────────────────────────────────────────────────────────

# ── SUPABASE (Dashboard Auth + Client SDK) ──────────────────────────────────
# Required for client-side Supabase SDK and SSR session management
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-side admin operations (user creation, deletion)
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── EXTERNAL API ────────────────────────────────────────────────────────────
# Base URL for the interpreters-api service (webhooks, external integrations)
NEXT_PUBLIC_API_URL="https://api.freeinterpreters.com"

# ── DATABASE (Prisma + pg Pool) ─────────────────────────────────────────────
# Transaction Pooler (port 6543) — ALL runtime queries route through here
# MUST include ?pgbouncer=true&connection_limit=5 to prevent pool exhaustion
DATABASE_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Direct connection (port 5432) — ONLY for schema migrations (prisma db push)
DIRECT_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:5432/postgres"

# ── AUTH.JS / NextAuth v5 (RBAC Portal) ─────────────────────────────────────
# JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-at-least-32-chars"

# Force Auth.js to trust the proxy (Traefik → container)
AUTH_TRUST_HOST="true"

# Callback URL base — must match the public URL of this service
NEXTAUTH_URL="https://admin.freeinterpreters.com"

# ── VAULT ENCRYPTION (AES-256-GCM) ─────────────────────────────────────────
# 64-char hex key for credential encryption at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-key-here"

# ── CORS ────────────────────────────────────────────────────────────────────
# Allowed origin for API cross-origin requests
CORS_ORIGIN="https://app.freeinterpreters.com"

# ── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="80"
HOSTNAME="0.0.0.0"
NEXT_TELEMETRY_DISABLED="1"
