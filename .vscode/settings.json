{
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true
  },
  "markdown.validate.ignoredPaths": [
    "**/node_modules/**"
  ],
  "markdownlint.exclude": [
    "**/node_modules/**"
  ],
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow": ".github/workflows/*.yml"
  }
}