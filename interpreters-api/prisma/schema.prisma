generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}


datasource db {
  provider  = "postgresql"
  schemas   = ["auth", "public"]
}



model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(INTERPRETER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Link to interpreter if it's an interpreter user
  interpreterId Int? @unique @map("interpreter_id")
  interpreter   Interpreter? @relation(fields: [interpreterId], references: [id])

  @@index([role])
  @@index([createdAt])
  @@map("users_api")
  @@schema("public")
}


enum Role {
  ADMIN
  INTERPRETER
  ACCOUNT_HOLDER

  @@schema("public")
}


model Interpreter {
  id               Int      @id @default(autoincrement())
  externalId       String   @unique @map("external_id")
  name             String
  emailCorporativo String?  @unique @map("email_corporativo")
  status           String?  @default("Activo")
  tariffPerMinute  Decimal  @map("tariff_per_minute") @db.Decimal(10, 2)
  
  user             User?
  productionLogs   ProductionLog[]
  payrollRecords   PayrollRecord[]

  @@index([status])
  @@index([name])
  @@map("interpreters")
  @@schema("public")
}


model ProductionLog {
  id                 Int      @id @default(autoincrement())
  interpreterId      Int      @map("interpreter_id")
  date               DateTime @db.Date
  interpretedMinutes Int      @default(0) @map("interpreted_minutes")
  verifiedMinutes    Int?     @map("verified_minutes")
  status             String
  
  accountId          Int?     @map("account_id")
  interpreter        Interpreter @relation(fields: [interpreterId], references: [id])

  @@unique([interpreterId, date, accountId])
  @@index([date])
  @@index([status])
  @@index([interpreterId])
  @@map("production_logs")
  @@schema("public")
}


model PayrollRecord {
  id            String   @id @default(uuid())
  interpreterId Int      @map("interpreter_id")
  periodStart   DateTime @map("period_start") @db.Date
  periodEnd     DateTime @map("period_end") @db.Date
  totalMinutes  Int      @map("total_minutes")
  grossTotal    Decimal  @map("gross_total") @db.Decimal(10, 2)
  netTotal      Decimal  @map("net_total") @db.Decimal(10, 2)
  status        String   @default("Pendiente")
  createdAt     DateTime @default(now()) @map("created_at")

  interpreter   Interpreter @relation(fields: [interpreterId], references: [id])

  @@index([interpreterId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payroll_records")
  @@schema("public")
}


// Extensiones para el modelo de Producción
model CallLog {
  id              String   @id @default(cuid())
  interpreterId   String
  startTime       DateTime
  endTime         DateTime
  durationSeconds Int      // Calculado automáticamente o manual
  isManualEntry   Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  
  @@index([interpreterId])
  @@index([startTime])
  @@index([createdAt])
  @@schema("public")
}
